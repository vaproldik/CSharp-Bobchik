<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="600" Width="900"
        Background="#F0F4F8">

    <Window.Resources>
        <!-- Стиль для кнопок -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль заголовка колонки -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#4A5568"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- ===== ЗАГОЛОВОК ===== -->
        <Border Grid.Row="0" Background="#2D3748">
            <StackPanel VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="📋 Task Manager"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Управление задачами"
                           FontSize="12"
                           Foreground="#A0AEC0"/>
            </StackPanel>
        </Border>

        <!-- ===== ПАНЕЛЬ УПРАВЛЕНИЯ ===== -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопка Создать -->
                <Button Grid.Column="0"
                        Content="＋ Создать"
                        Style="{StaticResource ActionButton}"
                        Background="#48BB78"
                        Margin="0,0,8,0"
                        Click="CreateTask_Click"/>

                <!-- Кнопка Изменить -->
                <Button Grid.Column="1"
                        Content="✏ Изменить"
                        Style="{StaticResource ActionButton}"
                        Background="#4299E1"
                        Margin="0,0,8,0"
                        Click="EditTask_Click"/>

                <!-- Кнопка Удалить -->
                <Button Grid.Column="2"
                        Content="🗑 Удалить"
                        Style="{StaticResource ActionButton}"
                        Background="#FC8181"
                        Click="DeleteTask_Click"/>

                <!-- Фильтр по статусу -->
                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <TextBlock Text="Статус:"
                               VerticalAlignment="Center"
                               Foreground="#4A5568"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="FilterStatusComboBox"
                              Width="150"
                              Height="32"
                              SelectionChanged="FilterStatusComboBox_SelectionChanged">
                        <ComboBoxItem Content="Все" IsSelected="True"/>
                        <ComboBoxItem Content="В работе"/>
                        <ComboBoxItem Content="Выполнено"/>
                        <ComboBoxItem Content="Отложено"/>
                    </ComboBox>
                </StackPanel>

                <!-- Поиск -->
                <Border Grid.Column="5"
                        BorderBrush="#CBD5E0"
                        BorderThickness="1"
                        CornerRadius="6"
                        VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox"
                             Width="180"
                             Height="32"
                             BorderThickness="0"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             FontSize="13"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Resources>
                                    <VisualBrush x:Key="HintBrush"
                                                 AlignmentX="Left"
                                                 AlignmentY="Center"
                                                 Stretch="None">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="🔍 Поиск задачи..."
                                                       Foreground="#A0AEC0"
                                                       FontSize="13"
                                                       Margin="8,0,0,0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background"
                                                Value="{StaticResource HintBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>
            </Grid>
        </Border>

        <!-- ===== СПИСОК ЗАДАЧ ===== -->
        <Grid Grid.Row="2" Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовки колонок -->
            <Border Grid.Row="0"
                    Background="#EDF2F7"
                    CornerRadius="6,6,0,0"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#"
                               Style="{StaticResource HeaderText}"/>
                    <TextBlock Grid.Column="1" Text="Название задачи"
                               Style="{StaticResource HeaderText}"/>
                    <TextBlock Grid.Column="2" Text="Приоритет"
                               Style="{StaticResource HeaderText}"/>
                    <TextBlock Grid.Column="3" Text="Статус"
                               Style="{StaticResource HeaderText}"/>
                    <TextBlock Grid.Column="4" Text="Описание"
                               Style="{StaticResource HeaderText}"/>
                </Grid>
            </Border>

            <!-- ListBox с задачами -->
            <ListBox Grid.Row="1"
                     x:Name="TasksListBox"
                     BorderThickness="1"
                     BorderBrush="#E2E8F0"
                     Background="White"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="TasksListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EBF8FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F7FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10"
                                BorderBrush="#EDF2F7"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <!-- ID -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Id}"
                                           Foreground="#A0AEC0"
                                           VerticalAlignment="Center"/>

                                <!-- Название -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontWeight="Medium"
                                           FontSize="14"
                                           Foreground="#2D3748"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Приоритет (Badge) -->
                                <Border Grid.Column="2"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Priority}"
                                                             Value="Высокий">
                                                    <Setter Property="Background" Value="#FED7D7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}"
                                                             Value="Средний">
                                                    <Setter Property="Background" Value="#FEFCBF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}"
                                                             Value="Низкий">
                                                    <Setter Property="Background" Value="#C6F6D5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Priority}"
                                               FontSize="12"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Priority}"
                                                                 Value="Высокий">
                                                        <Setter Property="Foreground" Value="#C53030"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}"
                                                                 Value="Средний">
                                                        <Setter Property="Foreground" Value="#975A16"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}"
                                                                 Value="Низкий">
                                                        <Setter Property="Foreground" Value="#276749"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Статус (Badge) -->
                                <Border Grid.Column="3"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="В работе">
                                                    <Setter Property="Background" Value="#BEE3F8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="Выполнено">
                                                    <Setter Property="Background" Value="#C6F6D5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="Отложено">
                                                    <Setter Property="Background" Value="#E9D8FD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="12"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}"
                                                                 Value="В работе">
                                                        <Setter Property="Foreground" Value="#2B6CB0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}"
                                                                 Value="Выполнено">
                                                        <Setter Property="Foreground" Value="#276749"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}"
                                                                 Value="Отложено">
                                                        <Setter Property="Foreground" Value="#553C9A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Описание -->
                                <TextBlock Grid.Column="4"
                                           Text="{Binding Description}"
                                           Foreground="#718096"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ===== СТАТУСНАЯ СТРОКА ===== -->
        <Border Grid.Row="3" Background="#2D3748" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="Готово"
                           Foreground="#A0AEC0"
                           VerticalAlignment="Center"
                           FontSize="12"/>

                <TextBlock x:Name="TotalCount"
                           Grid.Column="1"
                           Foreground="#A0AEC0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Margin="0,0,16,0"/>

                <TextBlock x:Name="InProgressCount"
                           Grid.Column="2"
                           Foreground="#63B3ED"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Margin="0,0,16,0"/>

                <TextBlock x:Name="DoneCount"
                           Grid.Column="3"
                           Foreground="#68D391"
                           VerticalAlignment="Center"
                           FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
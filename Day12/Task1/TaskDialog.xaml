<Window x:Class="Task1.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача" Height="380" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7FAFC">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок диалога -->
        <TextBlock x:Name="DialogTitle"
                   Grid.Row="0"
                   Text="Новая задача"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#2D3748"
                   Margin="0,0,0,20"/>

        <!-- Форма -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">

            <!-- Название -->
            <TextBlock Text="Название задачи *"
                       Foreground="#4A5568"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="TitleBox"
                     Height="36"
                     Padding="10,0"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     BorderBrush="#CBD5E0"
                     Margin="0,0,0,14"/>

            <!-- Приоритет (ComboBox) -->
            <TextBlock Text="Приоритет *"
                       Foreground="#4A5568"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="PriorityComboBox"
                      Height="36"
                      FontSize="14"
                      Margin="0,0,0,14">
                <ComboBoxItem Content="Высокий"/>
                <ComboBoxItem Content="Средний" IsSelected="True"/>
                <ComboBoxItem Content="Низкий"/>
            </ComboBox>

            <!-- Статус (ComboBox) -->
            <TextBlock Text="Статус *"
                       Foreground="#4A5568"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="StatusComboBox"
                      Height="36"
                      FontSize="14"
                      Margin="0,0,0,14">
                <ComboBoxItem Content="В работе" IsSelected="True"/>
                <ComboBoxItem Content="Выполнено"/>
                <ComboBoxItem Content="Отложено"/>
            </ComboBox>

            <!-- Описание -->
            <TextBlock Text="Описание"
                       Foreground="#4A5568"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="DescriptionBox"
                     Height="60"
                     Padding="10,8"
                     FontSize="13"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     BorderBrush="#CBD5E0"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Отмена"
                    Width="100" Height="36"
                    Margin="0,0,8,0"
                    Background="#EDF2F7"
                    Foreground="#4A5568"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="SaveButton"
                    Content="Сохранить"
                    Width="120" Height="36"
                    Background="#4299E1"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Save_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
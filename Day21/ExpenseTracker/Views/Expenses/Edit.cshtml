@model ExpenseTracker.ViewModels.ExpenseViewModel

@{
    ViewBag.Title = "Редактировать расход";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow">
                <div class="card-header bg-warning">
                    <h4 class="mb-0">✏️ Редактировать расход</h4>
                </div>
                <div class="card-body">

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()

                        <!-- Скрытый Id для передачи в POST -->
                        <input asp-for="Id" type="hidden" />

                        <!-- Название -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                        
                        <!-- Категория -->
                        <div class="mb-3">
                            <label asp-for="Category" class="form-label fw-bold"></label>
                            <div class="mb-3">
                                <label asp-for="Category" class="form-label fw-bold"></label>
                                <select asp-for="Category" class="form-select">
                                    <option value="">— Выберите категорию —</option>
                                    @foreach (var cat in ViewBag.Categories)
                                    {
                                        <option value="@cat" selected="@(Model.Category == cat)">
                                            @cat
                                        </option>
                                    }
                                </select>
                                <span asp-validation-for="Category" class="text-danger"></span>
                            </div>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>

                        <!-- Сумма -->
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <input asp-for="Amount"
                                       class="form-control"
                                       type="number"
                                       step="0.01"
                                       min="0.01" />
                                <span class="input-group-text">BYN</span>
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <!-- Дата -->
                        <div class="mb-3">
                            <label asp-for="Date" class="form-label fw-bold"></label>
                            <input asp-for="Date" class="form-control" type="date" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>

                        <!-- Кнопки -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning flex-fill">
                                💾 Сохранить изменения
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                                ❌ Отмена
                            </a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
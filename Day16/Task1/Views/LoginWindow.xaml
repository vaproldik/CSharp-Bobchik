<Window x:Class="Task1.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход — Task Manager"
        Height="511" Width="410"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F7FAFC">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="📋 Task Manager"
                   FontSize="24" FontWeight="Bold"
                   Foreground="#2D3748"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="Войдите в свой аккаунт"
                   FontSize="13" Foreground="#718096"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24"/>

        <TextBlock Grid.Row="2"
                   Text="Имя пользователя"
                   Foreground="#4A5568" FontWeight="SemiBold"
                   Margin="0,0,0,4"/>

        <TextBox Grid.Row="3"
                 x:Name="UsernameBox"
                 Height="38" Padding="10,0"
                 VerticalContentAlignment="Center"
                 FontSize="14" BorderBrush="#CBD5E0"
                 Margin="0,0,0,14"/>

        <TextBlock Grid.Row="4"
                   Text="Пароль"
                   Foreground="#4A5568" FontWeight="SemiBold"
                   Margin="0,0,0,4"/>

        <PasswordBox Grid.Row="5"
                     x:Name="PwdBox"
                     Height="38" Padding="10,0"
                     FontSize="14" BorderBrush="#CBD5E0"
                     Margin="0,0,0,20"/>

        <StackPanel Grid.Row="6">
            <Button Content="Войти"
                    Height="38" FontSize="14"
                    Background="#4299E1" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,0,10"
                    Click="LoginButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Нет аккаунта? Зарегистрироваться"
                    Height="38" FontSize="13"
                    Background="#EDF2F7" Foreground="#4A5568"
                    BorderThickness="0" Cursor="Hand"
                    Click="OpenRegisterButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock x:Name="MessageText"
                       Foreground="#E53E3E" FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
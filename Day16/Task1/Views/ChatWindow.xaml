<Window x:Class="Task1.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат задач" Height="500" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F7FAFC">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="💬 Чат (Named Pipes)"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#2D3748"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Background="White">
            <ListBox x:Name="MessagesListBox"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="8"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#EBF8FF" CornerRadius="8"
                                Padding="10,6" Margin="0,3">
                            <TextBlock Text="{Binding}"
                                       TextWrapping="Wrap"
                                       Foreground="#2D3748" FontSize="13"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="InputBox"
                     Height="38" Padding="10,0"
                     VerticalContentAlignment="Center"
                     FontSize="13" BorderBrush="#CBD5E0"
                     Margin="0,0,8,0"
                     KeyDown="InputBox_KeyDown"/>

            <Button Grid.Column="1"
                    Content="Отправить"
                    Height="38" FontSize="13"
                    Background="#4299E1" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="SendButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
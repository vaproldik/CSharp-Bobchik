@model List<ExpenseTracker.Models.Expense>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@{
    ViewData["Title"] = "Список расходов";
}

<h2>Список расходов</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить расход</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Сумма</th>
            <th>Категория</th>
            <th>Дата</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Amount</td>
                <td>@item.Category</td>
                <td>@item.Date.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>

<hr />

<h4>Фильтрация по категории</h4>

<div class="d-flex gap-2">
    <input type="text" id="categoryInput"
           class="form-control"
           placeholder="Например: Еда"
           style="max-width: 300px;" />

    <button class="btn btn-secondary" onclick="filterCategory()">
        Фильтровать
    </button>

    <a asp-action="Index" class="btn btn-outline-danger">
        Сбросить
    </a>
</div>

<script>
    function filterCategory() {
        var category = document.getElementById("categoryInput").value;

        if (category.trim() === "") {
            alert("Введите категорию!");
            return;
        }

        window.location.href = "/Expenses/Filter/" + encodeURIComponent(category);
    }
</script>
<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Task1.ViewModels"
        Title="Task Manager" Height="650" Width="980"
        Background="#F0F4F8">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- ===== ГОРЯЧИЕ КЛАВИШИ ===== -->
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddTaskCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditTaskCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteTaskCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Меню -->
            <RowDefinition Height="Auto"/>
            <!-- Панель инструментов -->
            <RowDefinition Height="70"/>
            <!-- Заголовок -->
            <RowDefinition Height="*"/>
            <!-- Список задач -->
            <RowDefinition Height="40"/>
            <!-- Статусная строка -->
        </Grid.RowDefinitions>

        <!-- ===== ГЛАВНОЕ МЕНЮ ===== -->
        <Menu Grid.Row="0" Background="#2D3748" Foreground="White"
              FontSize="13">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#2D3748"/>
                </Style>
            </Menu.Resources>

            <!-- Файл -->
            <MenuItem Header="Файл">
                <MenuItem Header="Новая задача"
                          Command="{Binding AddTaskCommand}"
                          InputGestureText="Ctrl+N"/>
                <Separator/>
                <MenuItem Header="Выход"
                          Command="{Binding ExitCommand}"/>
            </MenuItem>

            <!-- Задачи -->
            <MenuItem Header="Задачи">
                <MenuItem Header="Создать задачу"
                          Command="{Binding AddTaskCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать задачу"
                          Command="{Binding EditTaskCommand}"
                          InputGestureText="Ctrl+E"/>
                <MenuItem Header="Удалить задачу"
                          Command="{Binding DeleteTaskCommand}"
                          InputGestureText="Ctrl+D"/>
                <Separator/>
                <MenuItem Header="Показать все"
                          Click="ShowAll_Click"/>
                <MenuItem Header="Только в работе"
                          Click="ShowInProgress_Click"/>
                <MenuItem Header="Только выполненные"
                          Click="ShowDone_Click"/>
            </MenuItem>

            <!-- Настройки -->
            <MenuItem Header="Настройки">
                <MenuItem Header="Светлая тема"  Click="ThemeLight_Click"/>
                <MenuItem Header="Тёмная тема"   Click="ThemeDark_Click"/>
            </MenuItem>

            <!-- Помощь -->
            <MenuItem Header="Помощь">
                <MenuItem Header="О программе"
                          Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ===== ПАНЕЛЬ ИНСТРУМЕНТОВ ===== -->
        <ToolBar Grid.Row="1"
                 Background="#EDF2F7"
                 Height="46">

            <Button Command="{Binding AddTaskCommand}"
                    ToolTip="Создать задачу (Ctrl+N)"
                    Margin="4,0" Padding="12,6"
                    Background="#48BB78" Foreground="White"
                    BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Создать" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Command="{Binding EditTaskCommand}"
                    ToolTip="Редактировать (Ctrl+E)"
                    Margin="4,0" Padding="12,6"
                    Background="#4299E1" Foreground="White"
                    BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✏" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Изменить" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Command="{Binding DeleteTaskCommand}"
                    ToolTip="Удалить (Ctrl+D)"
                    Margin="4,0" Padding="12,6"
                    Background="#FC8181" Foreground="White"
                    BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Удалить" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Separator Margin="8,0"/>

            <!-- Фильтр по статусу -->
            <TextBlock Text="Статус:" VerticalAlignment="Center"
                       Foreground="#4A5568" Margin="0,0,6,0"/>
            <ComboBox Width="150" Height="30"
                      SelectedValuePath="Content"
                      SelectionChanged="FilterComboBox_SelectionChanged"
                      x:Name="FilterComboBox">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="В работе"/>
                <ComboBoxItem Content="Выполнено"/>
                <ComboBoxItem Content="Отложено"/>
            </ComboBox>

            <Separator Margin="8,0"/>

            <!-- Поиск -->
            <TextBlock Text="Поиск:" VerticalAlignment="Center"
                       Foreground="#4A5568" Margin="0,0,6,0"/>
            <TextBox Width="180" Height="30"
                     Padding="8,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13"/>
        </ToolBar>

        <!-- ===== ЗАГОЛОВОК ===== -->
        <Border Grid.Row="2" Background="#2D3748">
            <StackPanel VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="📋 Task Manager"
                           FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Управление задачами"
                           FontSize="12" Foreground="#A0AEC0"/>
            </StackPanel>
        </Border>

        <!-- ===== СПИСОК ЗАДАЧ ===== -->
        <Grid Grid.Row="3" Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовки колонок -->
            <Border Grid.Row="0" Background="#EDF2F7"
                    CornerRadius="6,6,0,0" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#"
                               FontWeight="SemiBold" Foreground="#4A5568"/>
                    <TextBlock Grid.Column="1" Text="Название задачи"
                               FontWeight="SemiBold" Foreground="#4A5568"/>
                    <TextBlock Grid.Column="2" Text="Приоритет"
                               FontWeight="SemiBold" Foreground="#4A5568"/>
                    <TextBlock Grid.Column="3" Text="Статус"
                               FontWeight="SemiBold" Foreground="#4A5568"/>
                    <TextBlock Grid.Column="4" Text="Описание"
                               FontWeight="SemiBold" Foreground="#4A5568"/>
                </Grid>
            </Border>

            <!-- ListBox -->
            <ListBox Grid.Row="1"
                     x:Name="TasksListBox"
                     ItemsSource="{Binding FilteredTasks}"
                     SelectedItem="{Binding SelectedTask}"
                     BorderThickness="1" BorderBrush="#E2E8F0"
                     Background="White"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="TasksListBox_MouseDoubleClick">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EBF8FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F7FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10"
                                BorderBrush="#EDF2F7" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Id}"
                                           Foreground="#A0AEC0" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1" Text="{Binding Title}"
                                           FontWeight="Medium" FontSize="14"
                                           Foreground="#2D3748" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Бейдж приоритета -->
                                <Border Grid.Column="2" CornerRadius="12"
                                        Padding="10,4" HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Priority}" Value="Высокий">
                                                    <Setter Property="Background" Value="#FED7D7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="Средний">
                                                    <Setter Property="Background" Value="#FEFCBF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="Низкий">
                                                    <Setter Property="Background" Value="#C6F6D5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Priority}"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Priority}" Value="Высокий">
                                                        <Setter Property="Foreground" Value="#C53030"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}" Value="Средний">
                                                        <Setter Property="Foreground" Value="#975A16"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}" Value="Низкий">
                                                        <Setter Property="Foreground" Value="#276749"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Бейдж статуса -->
                                <Border Grid.Column="3" CornerRadius="12"
                                        Padding="10,4" HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="В работе">
                                                    <Setter Property="Background" Value="#BEE3F8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Выполнено">
                                                    <Setter Property="Background" Value="#C6F6D5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Отложено">
                                                    <Setter Property="Background" Value="#E9D8FD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="В работе">
                                                        <Setter Property="Foreground" Value="#2B6CB0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Выполнено">
                                                        <Setter Property="Foreground" Value="#276749"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Отложено">
                                                        <Setter Property="Foreground" Value="#553C9A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <TextBlock Grid.Column="4" Text="{Binding Description}"
                                           Foreground="#718096" FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ===== СТАТУСНАЯ СТРОКА ===== -->
        <Border Grid.Row="4" Background="#2D3748" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="#A0AEC0"
                           VerticalAlignment="Center" FontSize="12"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding TotalCount}"
                           Foreground="#A0AEC0"
                           VerticalAlignment="Center" FontSize="12"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding InProgressCount}"
                           Foreground="#63B3ED"
                           VerticalAlignment="Center" FontSize="12"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="3"
                           Text="{Binding DoneCount}"
                           Foreground="#68D391"
                           VerticalAlignment="Center" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
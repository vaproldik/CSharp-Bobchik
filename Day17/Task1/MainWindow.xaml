<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager"
        Height="660" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!--
            СТИЛЬ С АНИМАЦИЕЙ ПОЯВЛЕНИЯ
            Fade + Scale при загрузке элемента
        -->
        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>

                <!-- Анимация появления при загрузке -->
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                From="0" To="1"
                                Duration="0:0:0.35"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="RenderTransform.ScaleX"
                                From="0.85" To="1"
                                Duration="0:0:0.35"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="RenderTransform.ScaleY"
                                From="0.85" To="1"
                                Duration="0:0:0.35"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <!-- Импульс активных задач (В работе) -->
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PulseStoryboard">
                            <Storyboard RepeatBehavior="Forever"
                                        AutoReverse="True">
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.ScaleX"
                                    To="1.04"
                                    Duration="0:0:0.7"/>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.ScaleY"
                                    To="1.04"
                                    Duration="0:0:0.7"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>

            </Style.Triggers>
        </Style>

        <!-- ШАБЛОН ЗАДАЧИ -->
        <DataTemplate x:Key="TaskTemplate">

            <Border Style="{StaticResource TaskCardStyle}"
                    Margin="4" Padding="14,10"
                    CornerRadius="10"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    MouseLeftButtonDown="TaskCard_MouseLeftButtonDown">

                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2"
                                      BlurRadius="8"
                                      Opacity="0.15"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <!-- Название + категория -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#2D3748"/>
                        <TextBlock Text="{Binding Category}"
                                   FontSize="12"
                                   Foreground="#718096"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Статус -->
                    <Border Grid.Column="1"
                            CornerRadius="12"
                            Padding="10,4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{Binding StatusBrush}">
                        <TextBlock Text="{Binding Status}"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                    </Border>

                    <!-- Дедлайн -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding DeadlineText}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#4A5568"
                               FontSize="13"/>

                    <!-- Кнопка удаления -->
                    <Button Grid.Column="3"
                            Content="Удалить"
                            Height="30" Width="80"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#FC8181"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding DataContext.DeleteCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2D3748">
            <Grid Margin="16,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="📋 Task Manager"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock FontSize="12" Foreground="#A0AEC0">
                        <Run Text="Пользователь: "/>
                        <Run Text="{Binding CurrentUser, Mode=OneWay}"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Background="White">

            <Button Content="🔄 Загрузить"
                    Height="36" Padding="14,0" Margin="10,8"
                    Background="#4299E1" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding LoadCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="＋ Добавить"
                    Height="36" Padding="14,0" Margin="0,8"
                    Background="#48BB78" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding AddCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="💬 Чат"
                    Height="36" Padding="14,0" Margin="10,8"
                    Background="#9F7AEA" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding OpenChatCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>

        <!-- Уведомление -->
        <Border Grid.Row="2"
                Padding="16,8"
                Background="#EBF8FF"
                BorderBrush="#BEE3F8"
                BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NotificationText}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding NotificationText, Mode=OneWay}"
                       Foreground="#2B6CB0"
                       FontSize="13"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Индикатор загрузки -->
        <Border Grid.Row="3"
                Background="#FEFCBF"
                Padding="16,10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding LoadingText, Mode=OneWay}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#975A16"/>
        </Border>

        <!-- ListView с задачами -->
        <ListView Grid.Row="4"
                  x:Name="TaskListView"
                  Margin="10,8"
                  ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                  ItemTemplate="{StaticResource TaskTemplate}"
                  Background="Transparent"
                  BorderThickness="0"
                  AllowDrop="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Drop="TaskListView_Drop"
                  DragOver="TaskListView_DragOver"/>

        <!-- Статус строка -->
        <Border Grid.Row="5" Background="#2D3748" Padding="16,0">
            <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                       Foreground="#A0AEC0"
                       VerticalAlignment="Center"
                       FontSize="12"/>
        </Border>

    </Grid>
</Window>
<Window x:Class="Task1.Views.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача"
        Height="465" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7FAFC">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   x:Name="DialogTitle"
                   Text="Новая задача"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#2D3748"
                   Margin="0,0,0,20"/>

        <!-- Название -->
        <TextBlock Grid.Row="1"
                   Text="Название задачи *"
                   Foreground="#4A5568" FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <TextBox Grid.Row="2"
                 x:Name="TitleBox"
                 Height="38" Padding="10,0"
                 VerticalContentAlignment="Center"
                 FontSize="14" BorderBrush="#CBD5E0"
                 Margin="0,0,0,12"/>

        <!-- Категория -->
        <TextBlock Grid.Row="3"
                   Text="Категория"
                   Foreground="#4A5568" FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <ComboBox Grid.Row="4"
                  x:Name="CategoryBox"
                  Height="38" FontSize="14"
                  Margin="0,0,0,12">
            <ComboBoxItem Content="Работа"/>
            <ComboBoxItem Content="Учёба"/>
            <ComboBoxItem Content="Дом"/>
            <ComboBoxItem Content="Общее" IsSelected="True"/>
        </ComboBox>

        <!-- Приоритет / Статус -->
        <TextBlock Grid.Row="5"
                   Text="Статус"
                   Foreground="#4A5568" FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <ComboBox Grid.Row="6"
                  x:Name="StatusBox"
                  Height="38" FontSize="14"
                  Margin="0,0,0,12">
            <ComboBoxItem Content="Ожидание" IsSelected="True"/>
            <ComboBoxItem Content="В работе"/>
            <ComboBoxItem Content="Выполнено"/>
        </ComboBox>

        <!-- Дедлайн -->
        <TextBlock Grid.Row="7"
                   Text="Срок выполнения"
                   Foreground="#4A5568" FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <DatePicker Grid.Row="8"
                    x:Name="DeadlinePicker"
                    Height="38" FontSize="14"
                    Margin="0,0,0,20"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Отмена"
                    Width="100" Height="38"
                    Margin="0,0,8,0"
                    Background="#EDF2F7"
                    Foreground="#4A5568"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CancelButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="SaveButton"
                    Content="Сохранить"
                    Width="120" Height="38"
                    Background="#4299E1"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SaveButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>